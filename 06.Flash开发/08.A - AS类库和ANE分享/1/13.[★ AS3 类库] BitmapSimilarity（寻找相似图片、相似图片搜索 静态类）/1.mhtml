@charset "utf-8";

.wp { width: 1200px; }

#hd .wp, #wp { min-width: 1200px; }

.ct2 { margin-right: 222px; }

.ct2 .sd { margin-right: -235px; }

.ie7 .ct2 .sd { margin-left: 15px; }

.ie6 .ct2 .sd { padding-left: 15px; position: relative; }

.ct2 .mn { width: 940px; }

.ct2 #chart, .ct2 #an { margin-right: -235px; }

.ie6 .ct2 #chart, .ie6 .ct2 #an { position: relative; }

.ct2_a { padding-left: 150px; }

.ct2_a .appl { margin-left: -150px; }

.ie6 .ct2_a .appl { position: relative; display: inline; }

.ct2_a .mn { width: 99%; }

#nv_userapp .ct2_a .mn, .ct2_a_r .mn { width: 99%; }

.ct3_a { padding: 0px 240px 0px 160px; }

.ct3_a .appl { margin-left: -160px; }

.ie6 .ct3_a .appl, .ie6 .ct3_a .sd { display: inline; }

.ct3_a .sd { margin-right: -240px; }

.ct3_a .mn { margin: 0px; width: 100%; }

#nv { background-repeat: repeat-x; background-position: 0px -33px; }

#mu ul { border-bottom: 1px solid rgb(205, 205, 205); background-image: non=
e; background-color: rgb(242, 242, 242); }

.pg_post .ct2_a { margin-left: 0px; padding-left: 0px; }

.pg_post .ct2_a .appl { margin-left: 0px; background: none; }

.pg_modcp .ct2_a, .pg_announcement .ct2_a { border: none; }

.pg_modcp .ct2_a .mn, .pg_announcement .ct2_a .mn { margin-right: 0px; padd=
ing-top: 0px; }

.tdats .tdat { width: 20%; }

.tdats .tfxf { width: 79.5%; }

.tdats .tfx, .tdats .tb, .tscr { width: 39.5%; }

.tscr .tdat, .tscr .tdat th, .tscr .tdat td { width: 100%; }

.widthauto #toptb #diy-tg_menu { margin: -7px 0px 0px -1px; }

.widthauto .switchwidth { background-position: 100% -18px; }

.widthauto .switchwidth:hover { background: url("http://www.11ria.com/templ=
ate/qizhibbs/qizhiimages/switch_width.png") 100% -54px no-repeat; }

#nv, #mu { border-left: 0px solid rgb(205, 205, 205); border-right: 0px sol=
id rgb(205, 205, 205); }

#dcsignin { padding-left: 220px; }

#dcsignin .mn { width: 99%; }

#dcsignin .sd { margin-left: -220px; }

.ie6 #dcsignin .sd { margin-left: -138px; }
